/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a full size pipeline test.

    Use as follows:
        nextflow run nf-core/methylarray -profile test_full,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = "Full test profile"
    config_profile_description = "Full test dataset to check pipeline function"

    // Input data for full size test
    bs_genome_version = "hg38"
    input             = "https://raw.githubusercontent.com/ajandria/test-datasets/refs/heads/methylarray/testdata/test_full/test_full-input.csv"
    sample_metadata   = "https://raw.githubusercontent.com/ajandria/test-datasets/refs/heads/methylarray/testdata/test_full/test_full-extensive_metadata.csv"
}
