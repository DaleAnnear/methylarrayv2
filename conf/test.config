/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/methylarray -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    input           = "https://raw.githubusercontent.com/ajandria/test-datasets/refs/heads/methylarray/testdata/test/GSE43976/test-input.csv"
    sample_metadata = "https://raw.githubusercontent.com/ajandria/test-datasets/refs/heads/methylarray/testdata/test_full/test_full-extensive_metadata.csv"

    // Test profile parameters
    find_dmrs             = false
    adjust_batch_effect   = false
    xreactive_chr_targets = '3'
}
